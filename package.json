{
  "name": "luka-system",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "db:generate": "pnpm --filter @luka/database generate",
    "db:migrate": "pnpm --filter @luka/database migrate",
    "db:seed": "pnpm --filter @luka/database seed",
    "db:seed:demo": "pnpm --filter @luka/database seed:demo",
    "db:studio": "pnpm --filter @luka/database studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "15.5.15",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22 <25"
  }
}
