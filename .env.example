# Database
DATABASE_URL="postgresql://luka:luka_dev_2024@localhost:5432/luka_system?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# Auth
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# PAC (CFDI Provider) - Configure when contracted
